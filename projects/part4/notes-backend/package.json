{
  "name": "notes-backend",
  "version": "1.0.0",
  "description": "Notes app backend",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build:ui": "./build-ui.sh",
    "deploy": "vercel",
    "deploy:full": "npm run build:ui && npm run deploy",
    "dev": "NODE_ENV=development node --watch index.js",
    "lint": "eslint .",
    "start": "NODE_ENV=production node index.js",
    "test": "NODE_ENV=test node --test --test-isolation=none",
    "test:dev": "npm run test -- --watch"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "supertest": "^7.2.2"
  },
  "volta": {
    "node": "24.18.0",
    "npm": "12.0.1"
  }
}
